<Application x:Class="MediaApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0A0F"/>
        <SolidColorBrush x:Key="SurfaceBrush"    Color="#0E0E18"/>
        <SolidColorBrush x:Key="PanelBrush"      Color="#13131E"/>
        <SolidColorBrush x:Key="BorderBrush"     Color="#1A1A2A"/>
        <SolidColorBrush x:Key="GoldBrush"       Color="#C89B3C"/>
        <SolidColorBrush x:Key="GoldLightBrush"  Color="#F0C96A"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#EEEEFF"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#888899"/>
        <SolidColorBrush x:Key="TextMuted"       Color="#444466"/>

        <!-- ── Window base ── -->
        <Style TargetType="Window">
            <Setter Property="Background"  Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>

        <!-- ── Slim dark scrollbar ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- ── ToolTip ── -->
        <Style TargetType="ToolTip">
            <Setter Property="Background"      Value="#13131E"/>
            <Setter Property="Foreground"      Value="#C89B3C"/>
            <Setter Property="BorderBrush"     Value="#2A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="8,4"/>
        </Style>

    </Application.Resources>
</Application>
